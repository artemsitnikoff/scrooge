SCROOGE_BOT_TOKEN=your-telegram-bot-token-here
SCROOGE_HOST=0.0.0.0
SCROOGE_PORT=8000
# Оставить пустым для polling, указать URL для webhook:
SCROOGE_WEBHOOK_URL=
# URL ФГИС УТКО API (прод: https://api.utko.mnr.gov.ru/reo-weight-control-api/api/v1)
SCROOGE_UTKO_BASE_URL=https://api.utko.mnr.gov.ru/reo-weight-control-api/api/v1
# API-токен для доступа к REST API (Authorization: Bearer <token>)
SCROOGE_API_TOKEN=
# Токен платежной системы (ЮKassa через BotFather)
SCROOGE_PROVIDER_TOKEN=
